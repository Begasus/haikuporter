BUILD()
{
	cmake -Bbuild -S. $cmakeDirArgs \
		-DCMAKE_BUILD_TYPE=Release \
		-DKDE_INSTALL_PLUGINDIR=$addOnsDir/Qt6 \
		-DKDE_INSTALL_QMLDIR=$dataDir/Qt6/qml \
		-DECM_MKSPECS_INSTALL_DIR=$dataDir/Qt6/mkspecs \
		-DECM_DIR=/system/data/cmake/Modules/ECM/cmake
	make -C build $jobArgs
}

INSTALL()
{
	make -C build install

	# cleanup
	rm -rf $dataDir/{applications,icons,metainfo}

	mkdir -p "$dataDir/deskbar/menu/Applications/KDE"

	local MAJOR="`echo "$portVersion" | cut -d. -f1`"
	local MIDDLE="`echo "$portVersion" | cut -d. -f2`"
	local MINOR="`echo "$portVersion" | cut -d. -f3`"
	local APP_NAME="ProjecX"
	local LONG_INFO="$SUMMARY"
	local APP_SIGNATURE="application/x-vnd.projectx"
	sed \
		-e "s|@MAJOR@|$MAJOR|" \
		-e "s|@MIDDLE@|$MIDDLE|" \
		-e "s|@MINOR@|$MINOR|" \
		-e "s|@LONG_INFO@|$LONG_INFO|" \
		-e "s|@APP_NAME@|$APP_NAME|" \
		-e "s|@APP_SIGNATURE@|$APP_SIGNATURE|" \
		$portDir/additional-files/projectx.rdef.in > projectx.rdef

	addResourcesToBinaries projectx.rdef $binDir/projectx
	addAppDeskbarSymlink $binDir/projectx "KDE/ProjecX"

	prepareInstalledDevelLibs \
		projectx

	packageEntries devel \
		$developDir \
		$dataDir/Qt6/mkspecs \
		$libDir/cmake
}

TEST()
{
#	export LIBRARY_PATH="$sourceDir/build/bin${LIBRARY_PATH:+:$LIBRARY_PATH}"
	ctest --test-dir build --output-on-failure
#	make -C build test
}
